# Supabase edge function runtime secrets
SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
SUPABASE_SERVICE_ROLE_KEY="YOUR_SUPABASE_SERVICE_ROLE_KEY"

# Comma-separated list of allowed browser origins.
# Include your production origin (for this repo: https://nji-louis.github.io) and local dev hosts.
# Leave empty to allow all origins (not recommended for production).
ALLOWED_ORIGINS="http://127.0.0.1:5500,http://localhost:5500,https://nji-louis.github.io"

# Extra entropy for rate-limit identifier hashing.
RATE_LIMIT_PEPPER="CHANGE_ME_TO_A_LONG_RANDOM_STRING"
